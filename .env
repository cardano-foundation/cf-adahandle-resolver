# Mainnet QA / full-sync stack for cf-adahandle-resolver (docker-compose.yml).
# No secrets here beyond a throwaway local Postgres password — safe to commit.

# Spring profiles: mainnet network + postgres storage.
SPRING_ACTIVE_PROFILES=mainnet,postgres

# Postgres
POSTGRES_PASSWORD=adahandle1337_
DB_USERNAME=cardano
DB_PASSWORD=adahandle1337_
DB_NAME=adahandle
DB_HOST=db
DB_PORT=5432
DB_URL=jdbc:postgresql://${DB_HOST}:5432/${DB_NAME}

# API
PORT=9095
API_LOCAL_BIND_PORT=9095
API_IMAGE_TAG=local

# Cardano node (mainnet). CF backbone relay — a round-robin DNS pool.
REMOTE_NODE_URL=backbone.mainnet.cardanofoundation.org
REMOTE_NODE_PORT=3001

# Sync window: start at the first ADA Handle minting block, run to tip.
# (Same slot/hash the application.yml uses as the mainnet default.)
YACI_STORE_CARDANO_SYNC_START_SLOT=47931310
YACI_STORE_CARDANO_SYNC_START_BLOCK_HASH=89f93419845d5f6ce8040fd5eeedda93d764c8569f7c2cc6802a8429a0da877b
STORE_SYNCAUTOSTART=true

# JVM. See docker-compose.yml note: JAVA_TOOL_OPTIONS (not JAVA_OPTS) because the
# image entrypoint is a fixed `java -jar`. DNS ttl=0 avoids the dead-relay-IP wedge.
JAVA_TOOL_OPTIONS=-Xmx2g -Dnetworkaddress.cache.ttl=0 -Dnetworkaddress.cache.negative.ttl=0
